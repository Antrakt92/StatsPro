package-as: StatsPro

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - .github
  - .gitignore
  - README.md
  - .pkgmeta
  - .luacheckrc
  - .luarc.json
  - scripts
  - docs
  - screenshots
  - AUDIT.md
  - AGENTS.md
  - PLAN.md
  - NOTES.md
  - "*.private.md"
  - libs/LibStub/tests
  - libs/LibStub/*.toc
  - libs/CallbackHandler-1.0/*.xml
  - libs/LibSharedMedia-3.0/*.xml
