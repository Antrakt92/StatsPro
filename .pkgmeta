package-as: StatsPro

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - .github
  - .gitignore
  - README.md
  - LICENSE
  - .pkgmeta
  - screenshots

externals:
  libs/LibStub:
